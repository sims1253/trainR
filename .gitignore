# Posit-gskill .gitignore

# =============================================================================
# Python
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# =============================================================================
# R
# =============================================================================

# R history
.Rhistory
.Rapp.history

# R data files
.RData
.Ruserdata

# RStudio
.Rproj.user/

# renv
renv/
renv.lock

# =============================================================================
# Docker
# =============================================================================

# Docker volumes (if mounted locally)
.docker/

# =============================================================================
# Project-specific
# =============================================================================

# Environment variables (contains secrets)
.env
.env.local
.env.*.local

# Generated tasks (uncomment if you want to track them)
# tasks/train/*.json
# tasks/dev/*.json
# tasks/held_out/*.json

# Results and checkpoints
results/
checkpoints/

# Logs
logs/
*.log

# Cache
.cache/

# Large data files
data/
packages/

# Jupyter notebooks
.ipynb_checkpoints/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS files
.DS_Store
Thumbs.db

# Claude CLI
.claude/

# Snapshot files (updated by tests)
# tests/testthat/_snaps/
