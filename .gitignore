# Posit-gskill .gitignore

# =============================================================================
# Python
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# =============================================================================
# R
# =============================================================================

# R history
.Rhistory
.Rapp.history

# R data files
.RData
.Ruserdata

# RStudio
.Rproj.user/

# renv
renv/
renv.lock

# =============================================================================
# Docker
# =============================================================================

# Docker volumes (if mounted locally)
.docker/

# =============================================================================
# Node.js / Bun / Next.js
# =============================================================================

# Dependencies
node_modules/

# Lock files (optional - some projects track these)
bun.lock
package-lock.json
yarn.lock

# Bun
.bun/

# Yarn PnP
.pnp
.pnp.*

# Next.js
.next/
/out/

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing
/coverage

# Production build
/build

# =============================================================================
# Project-specific
# =============================================================================

# Environment variables (contains secrets)
.env
.env.local
.env.*.local

# Generated tasks (uncomment if you want to track them)
# tasks/train/*.json
# tasks/dev/*.json
# tasks/held_out/*.json
# Canonical v1 migration outputs (generated locally)
tasks_v1/
tasks_v1_split/

# Results and checkpoints
results/
checkpoints/

# Logs
logs/
*.log

# Cache
.cache/

# Large data files
data/
packages/

# Jupyter notebooks
.ipynb_checkpoints/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS files
.DS_Store
Thumbs.db
*.pem

# Claude CLI
.claude/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# Benchmark outputs
# =============================================================================
container_logs/
output/

# =============================================================================
# Ad-hoc scratch scripts at repo root
# =============================================================================
/test_*.py
divide-and-conquer-*.Rmd

# =============================================================================
# Personal git config
# =============================================================================
.gitconfig

# =============================================================================
# Exceptions - DO NOT IGNORE
# =============================================================================

# Visualizer source directories that must be tracked
!visualizer/src/lib/
!visualizer/src/data/

# Track Dockerfile.benchmark
!Dockerfile.benchmark

# =============================================================================
# Factory / design artifacts (local, not for version control)
# =============================================================================
.factory/validation/
design/

.env