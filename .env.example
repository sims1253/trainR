# Posit-gskill Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Configuration (z.ai)
# =============================================================================

# Agent type: "litellm" or "claude_code"
LLM_AGENT_TYPE=litellm

# z.ai API configuration
# API key is NOT stored in this file for security.
# Set Z_AI_API_KEY in your shell config instead:
#   Fish: ~/.config/fish/conf.d/secrets.fish
#     set -gx Z_AI_API_KEY "your-key-here"
#   Bash/Zsh: ~/.bashrc or ~/.zshrc
#     export Z_AI_API_KEY="your-key-here"

# z.ai endpoint (for LiteLLM)
# Note: LiteLLM appends /v1/messages for Anthropic models, so use base URL only
LLM_API_BASE=https://api.z.ai

# Model selection (LiteLLM format with z.ai models)
# Implementing agent - fast, efficient for test generation
LLM_MODEL_TASK=openai/glm-4.7-flash

# Reflection/judge model - stronger for GEPA optimization
LLM_MODEL_REFLECTION=openai/glm-5

# Claude Code settings (if using claude_code agent type)
LLM_CLAUDE_CODE_PATH=claude
LLM_CLAUDE_CODE_TIMEOUT=300

# =============================================================================
# Claude Code with z.ai Backend (for claude_code agent type)
# =============================================================================
# Uncomment and set these to use Claude Code CLI with z.ai:
# ANTHROPIC_AUTH_TOKEN=your_zai_api_key_here
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# API_TIMEOUT_MS=3000000

# Model mapping for Claude Code with z.ai:
# ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.7-flash
# ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.7
# ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5

# =============================================================================
# OpenRouter Configuration (Alternative Provider)
# =============================================================================
# Uncomment and configure if using OpenRouter:
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=your_openrouter_key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=${OPENROUTER_API_KEY}
# LLM_API_BASE=${OPENROUTER_BASE_URL}
# LLM_MODEL_TASK=anthropic/claude-sonnet-4
# LLM_MODEL_REFLECTION=openai/gpt-5-turbo

# =============================================================================
# z.ai Coding Plan Configuration
# =============================================================================
# Uncomment and configure if using z.ai (already the default above):
# LLM_PROVIDER=zai
# LLM_API_KEY=your_zai_key
# LLM_API_BASE=https://api.z.ai/v1
# LLM_MODEL_TASK=anthropic/claude-sonnet-4-20250514
# LLM_MODEL_REFLECTION=openai/gpt-5

# =============================================================================
# Anthropic Direct Configuration (Alternative Provider)
# =============================================================================
# Uncomment for direct Anthropic usage:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# LLM_API_KEY=${ANTHROPIC_API_KEY}
# LLM_MODEL_TASK=claude-3-5-sonnet-20241022
# LLM_MODEL_REFLECTION=claude-3-5-sonnet-20241022

# =============================================================================
# Claude/LLM Settings
# =============================================================================

# Max tokens for responses
LLM_MAX_TOKENS=4096

# Temperature (0.0 - 1.0, lower = more deterministic)
LLM_TEMPERATURE=0.7

# Claude CLI version pin (for Docker and local install)
CLAUDE_CLI_VERSION=2.1.49

# Claude CLI installation path
CLAUDE_CODE_PATH=/usr/local/bin/claude

# =============================================================================
# GEPA Optimization Settings
# =============================================================================

# Population size for evolutionary algorithm
GEPA_POPULATION_SIZE=20

# Maximum generations
GEPA_MAX_GENERATIONS=50

# Mutation rate (0.0 - 1.0)
GEPA_MUTATION_RATE=0.15

# Crossover rate (0.0 - 1.0)
GEPA_CROSSOVER_RATE=0.7

# Elite size (number of top performers preserved)
GEPA_ELITE_SIZE=4

# Random seed for reproducibility
GEPA_SEED=42

# =============================================================================
# Evaluation Settings
# =============================================================================

# Timeout per task in seconds
EVALUATION_TIMEOUT=300

# Batch size for parallel evaluation
EVALUATION_BATCH_SIZE=10

# Number of parallel workers
EVALUATION_PARALLEL_WORKERS=4

# Number of repeats for non-determinism handling
EVALUATION_NUM_REPEATS=2

# =============================================================================
# Docker Settings
# =============================================================================

# Docker image name
DOCKER_IMAGE=posit-gskill-eval

# Docker image tag
DOCKER_TAG=latest

# =============================================================================
# Experiment Tracking Settings
# =============================================================================

# MLflow tracking URI
MLFLOW_TRACKING_URI=sqlite:///experiments/mlflow.db

# MLflow experiment name
MLFLOW_EXPERIMENT_NAME=posit-gskill-optimization

# Enable artifact logging
EXPERIMENT_LOG_ARTIFACTS=true

# Artifact storage location
EXPERIMENT_ARTIFACT_ROOT=./experiments/artifacts

# =============================================================================
# Paths
# =============================================================================

# Source packages directory
PACKAGES_DIR=./packages

# Tasks output directory
TASKS_DIR=./tasks

# Skills directory
SKILLS_DIR=./skills

# Results output directory
RESULTS_DIR=./results

# Checkpoints directory
CHECKPOINTS_DIR=./checkpoints

# =============================================================================
# Logging
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/posit-gskill.log

# =============================================================================
# Development
# =============================================================================

# Enable debug mode
DEBUG=false

# Dry run mode (skip actual API calls)
DRY_RUN=false

# Verbose output
VERBOSE=true
