# trainR environment configuration
# Copy this file to `.env` and fill in your values.
#
# Resolution order:
# 1) Existing shell/CI environment variables
# 2) Values in `.env`
#
# trainR normalizes API key aliases:
# - Canonical: Z_AI_API_KEY
# - Alias: ZAI_API_KEY
# If either is set, trainR keeps both names in sync for compatibility.

# ---------------------------------------------------------------------------
# Required API keys (set at least the providers you actually use)
# ---------------------------------------------------------------------------

# OPENROUTER_API_KEY=
# OPENCODE_API_KEY=
# Z_AI_API_KEY=

# Optional compatibility alias used by some external tooling.
# You can set this instead of Z_AI_API_KEY; trainR will normalize it.
# ZAI_API_KEY=
# OPENCODE_API_TOKEN=
# GOOGLE_API_KEY=
# ANTHROPIC_AUTH_TOKEN=

# Optional direct-provider keys
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# KIMI_API_KEY=

# ---------------------------------------------------------------------------
# Optional tokens
# ---------------------------------------------------------------------------

# Used by PR mining if present; otherwise gh CLI auth can be used.
# GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Optional model overrides
# ---------------------------------------------------------------------------

# LLM_MODEL_TASK=gpt-oss-120b
# LLM_MODEL_REFLECTION=glm-5
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# trainR env bootstrap controls
# ---------------------------------------------------------------------------

# Disable automatic `.env` loading when needed (1/0, true/false).
# TRAINR_LOAD_DOTENV=1

# Load a custom env file path instead of ./\.env
# TRAINR_DOTENV_PATH=/absolute/path/to/.env
