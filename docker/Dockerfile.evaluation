# Minimal evaluation image for R package testing
FROM rocker/r-ver:4.5.2

LABEL maintainer="trainR"
LABEL description="Evaluation sandbox for trainR skill optimization"

ENV DEBIAN_FRONTEND=noninteractive

# ── Layer 1: System deps (rarely changes) ──────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    gettext-base \
    libcurl4-openssl-dev \
    libssl-dev \
    libxml2-dev \
    && rm -rf /var/lib/apt/lists/*

# ── Layer 2: R packages (slowest, changes least) ───────────────────────────
RUN Rscript -e "install.packages('pak')"
RUN Rscript -e "pak::pak(c('testthat', 'devtools', 'covr', 'withr', 'mockr', 'jsonlite'))"
RUN Rscript -e "pak::pak('cli')"

# ── Layer 3: Node.js (changes rarely) ──────────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── Layer 4: Non-root user (Claude CLI refuses --dangerously-skip-permissions as root)
RUN useradd -m -s /bin/bash trainr \
    && mkdir -p /home/trainr/.local/bin \
    && mkdir -p /workspace/.claude/skills/testing-r-packages \
    && mkdir -p /workspace/packages \
    && chown -R trainr:trainr /workspace /home/trainr

# ── Layer 5: Bun (for bunx to run Pi CLI) ───────────────────────────────────
# Install bun for the trainr user so they can run bunx
USER trainr
RUN curl -fsSL https://bun.sh/install | bash
USER root
# Add trainr's bun to PATH globally for convenience
ENV PATH="/home/trainr/.bun/bin:${PATH}"

# ── Layer 6: Pi CLI (pinned version) ───────────────────────────────────────
# Install Pi CLI globally with pinned version for reproducibility
USER trainr
RUN /home/trainr/.bun/bin/bun install -g @mariozechner/pi-coding-agent@0.56
USER root

COPY docker/models.json /home/trainr/models.json

# ── Layer 7: Pi tool trace extension ───────────────────────────────────────
# Install extension for logging tool execution events to stdout
COPY docker/pi-tool-trace-extension.ts /opt/pi-extensions/pi-tool-trace-extension.ts
RUN chmod 644 /opt/pi-extensions/pi-tool-trace-extension.ts

# ── Layer 8: Workspace + entrypoint (changes most often) ───────────────────
ENV PATH="/home/trainr/.local/bin:${PATH}"

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /workspace

ENTRYPOINT ["/entrypoint.sh"]
CMD []
